{
  "$schema": "https://schema.tauri.app/config/2.json",
  "productName": "EMO Flashcards",
  "version": "0.1.0",
  "identifier": "com.emo.flashcards",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "EMO Flashcards",
        "width": 1160,
        "height": 800,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
